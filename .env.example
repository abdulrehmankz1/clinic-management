# MongoDB must be a REPLICA SET — transactions (the booking guard) require it.
# Local: `docker compose up -d` gives a single-node rs0.
DATABASE_URL=mongodb://127.0.0.1:27017/clinic-management?replicaSet=rs0

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- v3 reminders (all optional in dev) ---

# Resend API key. Absent => email features are silently off (graceful degradation).
RESEND_API_KEY=
# Sender address; the resend.dev default only delivers to the Resend account owner.
EMAIL_FROM=matab <onboarding@resend.dev>
# Required in prod — guards /api/cron/*. Vercel Cron sends it as `Authorization: Bearer <secret>`.
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=
